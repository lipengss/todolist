{
    "name": "todo-desktop",
    "private": true,
    "version": "1.0.1",
    "description": "FocusWorkspace - 寰呭姙浜嬮」妗岄潰搴旂敤",
    "author": "FocusWorkspace",
    "main": "electron/main.js",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "electron:dev": "concurrently \"vite --strictPort\" \"wait-on http://localhost:5173 && electron .\"",
        "electron:build": "vite build && electron-builder"
    },
    "dependencies": {
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-form": "^0.1.8",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-scroll-area": "^1.2.10",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-slot": "^1.2.4",
        "date-fns": "^4.3.0",
        "echarts": "^6.1.0",
        "echarts-for-react": "^3.0.6",
        "lucide-react": "^0.487.0",
        "react": "^18.3.1",
        "react-day-picker": "^9.14.0",
        "react-dom": "^18.3.1",
        "tw-animate-css": "^1.4.0"
    },
    "pnpm": {
    "onlyBuiltDependencies": ["sharp", "electron", "esbuild"]
  },
  "devDependencies": {
        "@tailwindcss/vite": "^4.1.12",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "@vitejs/plugin-react": "^4.7.0",
        "autoprefixer": "^10.4.20",
        "concurrently": "^9.1.2",
        "electron": "33.4.11",
        "electron-builder": "^25.1.8",
        "postcss": "^8.5.4",
        "pptxgenjs": "^4.0.1",
        "sharp": "^0.34.5",
        "tailwindcss": "^4.1.12",
        "typescript": "^5.8.3",
        "vite": "^6.3.5",
        "wait-on": "^8.0.2"
    },
    "build": {
        "appId": "com.focusworkspace.todo",
        "productName": "FocusWorkspace",
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**/*",
            "electron/**/*"
        ],
        "mac": {
            "target": "dmg",
            "icon": "public/logo.png"
        },
        "win": {
            "target": "nsis",
            "icon": "public/logo.png"
        },
        "linux": {
            "target": "AppImage",
            "icon": "public/logo.png"
        },
        "publish": {
            "provider": "github",
            "releaseType": "release"
        }
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/lipengss/todolist.git"
    }
}
